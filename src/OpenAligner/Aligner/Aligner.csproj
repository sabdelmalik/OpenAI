<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>AdvancedAligner</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.5" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.5" />
    <PackageReference Include="Serilog.Enrichers.CallerInfo" Version="1.0.6" />
    <PackageReference Include="Serilog.Extensions.Hosting" Version="10.0.0" />
    <PackageReference Include="Serilog.Extensions.Logging" Version="10.0.0" />
    <PackageReference Include="Serilog.Sinks.File" Version="7.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AlignmentService\AlignmentService.csproj" />
    <ProjectReference Include="..\OpenAiAPI\OpenAiService.csproj" />
    <ProjectReference Include="..\Parser\Parser.csproj" />
    <ProjectReference Include="..\PromptBuilder\PromptBuilder.csproj" />
    <ProjectReference Include="..\Tokens\Tokens.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="ExampleEditor\ExampleEditorForm.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="ExampleEditor\HebrewGridView.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="ExampleEditor\TargetGridView.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="Properties\OpenAiSettings.Designer.cs">
      <DesignTimeSharedInput>True</DesignTimeSharedInput>
      <AutoGen>True</AutoGen>
      <DependentUpon>OpenAiSettings.settings</DependentUpon>
    </Compile>
    <Compile Update="ReferenceRangeSelection.cs">
      <SubType>Form</SubType>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <None Update="Properties\OpenAiSettings.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
      <LastGenOutput>OpenAiSettings.Designer.cs</LastGenOutput>
    </None>
  </ItemGroup>

</Project>